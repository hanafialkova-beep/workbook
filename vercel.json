{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/workbook-(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "redirects": [
    { "source": "/sesit-1-for-everyone-v2.html", "destination": "/workbook-for-everyone", "permanent": true },
    { "source": "/sesit-2-for-managers-v2.html", "destination": "/workbook-for-managers", "permanent": true },
    { "source": "/sesit-1-v2", "destination": "/workbook-for-everyone", "permanent": true },
    { "source": "/workbook-1-v2", "destination": "/workbook-for-everyone", "permanent": true }
  ],
  "rewrites": [
    { "source": "/sesit-1", "destination": "/sesit-1-pro-kazdeho.html" },
    { "source": "/sesit-2", "destination": "/sesit-2-pro-manazery.html" },
    { "source": "/workbook-1", "destination": "/sesit-1-for-everyone.html" },
    { "source": "/workbook-2", "destination": "/sesit-2-for-managers.html" },
    { "source": "/workbook-for-everyone", "destination": "/workbook-for-everyone.html" },
    { "source": "/workbook-for-managers", "destination": "/workbook-for-managers.html" }
  ]
}
